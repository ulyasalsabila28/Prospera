# ============================================================
# .env.example — Template Konfigurasi Prospera Backend
# ============================================================
# INSTRUKSI:
#   1. Salin file ini: cp .env.example .env
#   2. Isi nilai yang sebenarnya di file .env (JANGAN di-commit!)
#   3. File .env sudah terdaftar di .gitignore — aman.
#
# PERINGATAN KEAMANAN:
#   - JANGAN pernah mengisi nilai secret nyata di file ini.
#   - JANGAN pernah commit file .env ke repository.
# ============================================================

# --- Konfigurasi Database ---
DB_HOST=127.0.0.1
DB_USER=your_db_user
DB_PASSWORD=your_strong_db_password_here
DB_NAME=prospera_db
DB_PORT=3306

# --- JWT Secret (WAJIB: minimal 64 karakter, generate via perintah berikut) ---
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=GANTI_DENGAN_STRING_RANDOM_MINIMAL_64_KARAKTER

# --- Port Server ---
PORT=500

# --- CORS Origin (URL frontend yang diizinkan) ---
# Development: http://localhost:5173
# Production:  https://yourdomain.com
CORS_ORIGIN=http://localhost:5173

# --- Timezone (opsional, default: Asia/Jakarta) ---
# TIMEZONE=Asia/Jakarta

# --- Environment (development | production) ---
NODE_ENV=development
